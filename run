#!/usr/bin/env bash
#
# run - atalho para executar um passo de um exercicio.
#
# Uso:  bash run <exercicio>.<passo> [args extras...]
#   ex: bash run 3.1     -> executa EX03/01_MGM_instala-gerenciador.bash
#       bash run 3.2     -> executa EX03/02_N1-N2_instala-no-de-dados.bash
#
# Funciona clonado (usa o arquivo local) ou sozinho (baixa o script do GitHub).
#
set -uo pipefail

USUARIO="paulo-granthon"
REPO="bdd"
BRANCH="main"
RAW="https://raw.githubusercontent.com/${USUARIO}/${REPO}/${BRANCH}"
API="https://api.github.com/repos/${USUARIO}/${REPO}/contents"

if [ $# -lt 1 ]; then
  echo "Uso: bash run <exercicio>.<passo> [args...]   (ex: bash run 3.1)" >&2
  exit 1
fi

alvo="$1"; shift
echo "[run] alvo: ${alvo}"

ex="${alvo%%.*}"
passo="${alvo#*.}"
case "$ex"    in ''|*[!0-9]*) echo "[run] exercicio invalido em '${alvo}' (use ex: 3.1)" >&2; exit 1;; esac
case "$passo" in ''|*[!0-9]*) echo "[run] passo invalido em '${alvo}' (use ex: 3.1)"     >&2; exit 1;; esac

exdir=$(printf "EX%02d" "$((10#$ex))")
pre=$(printf "%02d" "$((10#$passo))")
echo "[run] procurando ${exdir}/${pre}_* ..."

# 1) Arquivo local (repositorio clonado)?
raiz=$(cd "$(dirname "$0")" 2>/dev/null && pwd || echo ".")
script=""
for f in "${raiz}/${exdir}/${pre}_"*.bash "${raiz}/${exdir}/${pre}_"*.sh; do
  [ -f "$f" ] && { script="$f"; break; }
done
if [ -n "$script" ]; then
  echo "[run] executando local: ${exdir}/$(basename "$script")"
  exec bash "$script" "$@"
fi

# 2) Sem arquivo local: descobre o nome. Primeiro pelo manifesto (sem rede) e,
#    se nao conhecer o passo, cai para a API do GitHub.
nome=""
case "${exdir}/${pre}" in
  EX03/01) nome="01_MGM_instala-gerenciador.bash" ;;
  EX03/02) nome="02_N1-N2_instala-no-de-dados.bash" ;;
  EX03/03) nome="03_MGM_verifica-cluster.bash" ;;
  EX03/04) nome="04_N1_cria-banco-e-insere.bash" ;;
  EX03/05) nome="05_N2_verifica-replicacao.bash" ;;
esac

baixar() { wget -qO- "$1" 2>/dev/null || curl -fsSL "$1" 2>/dev/null; }

if [ -n "$nome" ]; then
  url="${RAW}/${exdir}/${nome}"
else
  echo "[run] consultando o GitHub para descobrir o passo..."
  url=$(baixar "${API}/${exdir}?ref=${BRANCH}" \
        | grep -oE '"download_url": *"[^"]+"' | grep -oE 'https://[^"]+' \
        | grep -E "/${exdir}/${pre}_[^/]+\.(bash|sh)$" | head -n1)
fi

if [ -z "${url:-}" ]; then
  echo "[run] nao encontrei o passo ${ex}.${passo} (${exdir}/${pre}_*)." >&2
  exit 1
fi

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
echo "[run] baixando: ${url##*/}"
if ! baixar "$url" > "$tmp" || [ ! -s "$tmp" ]; then
  echo "[run] falha ao baixar o script (sem internet? repo/branch errado?)." >&2
  exit 1
fi
echo "[run] executando: ${url##*/}"
bash "$tmp" "$@"
