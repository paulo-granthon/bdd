#!/usr/bin/env bash
#
# run - atalho para executar um passo de um exercicio.
#
# Uso:  bash run <exercicio>.<passo> [args extras...]
#   ex: bash run 3.1     -> executa EX03/01_MGM_instala-gerenciador.bash
#       bash run 3.2     -> executa EX03/02_N1-N2_instala-no-de-dados.bash
#
# Funciona de duas formas:
#   - dentro do repositorio clonado: usa o arquivo local;
#   - baixado sozinho (via wget): descobre o nome do script no GitHub e baixa.
#
set -euo pipefail

USUARIO="paulo-granthon"
REPO="bdd-cluster-scripts"
BRANCH="main"
API="https://api.github.com/repos/${USUARIO}/${REPO}/contents"

if [ $# -lt 1 ]; then
  echo "Uso: bash run <exercicio>.<passo> [args...]   (ex: bash run 3.1)" >&2
  exit 1
fi

alvo="$1"; shift
ex="${alvo%%.*}"
passo="${alvo#*.}"
if [ "$ex" = "$alvo" ] || [ -z "$passo" ]; then
  echo "Formato invalido: '$alvo'. Use <exercicio>.<passo>, ex: 3.1" >&2
  exit 1
fi

# Normaliza para os nomes do repo: EX03 / 01_...
exdir=$(printf "EX%02d" "$((10#$ex))")
pre=$(printf "%02d" "$((10#$passo))")

# 1) Tenta achar o script localmente (repo clonado).
raiz=$(cd "$(dirname "$0")" && pwd)
script=""
for f in "${raiz}/${exdir}/${pre}_"*.bash "${raiz}/${exdir}/${pre}_"*.sh; do
  if [ -f "$f" ]; then script="$f"; break; fi
done

if [ -n "$script" ]; then
  echo "[run] executando local: ${exdir}/$(basename "$script")"
  exec bash "$script" "$@"
fi

# 2) Sem arquivo local: descobre o nome no GitHub e baixa.
echo "[run] arquivo local nao encontrado, procurando ${exdir}/${pre}_* no GitHub..."
baixar() { wget -qO- "$1" 2>/dev/null || curl -fsSL "$1" 2>/dev/null; }

listagem=$(baixar "${API}/${exdir}?ref=${BRANCH}" || true)
url=$(printf '%s' "$listagem" \
  | grep -oE '"download_url": *"[^"]+"' \
  | grep -oE 'https://[^"]+' \
  | grep -E "/${exdir}/${pre}_[^/]+\.(bash|sh)$" \
  | head -n1)

if [ -z "$url" ]; then
  echo "[run] nao achei o passo ${ex}.${passo} (${exdir}/${pre}_*) no repositorio." >&2
  exit 1
fi

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
echo "[run] baixando: $(basename "$url")"
baixar "$url" > "$tmp"
bash "$tmp" "$@"
